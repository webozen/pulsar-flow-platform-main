{
  "name": "app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3002",
    "build": "next build",
    "start": "next start -p 3002",
    "lint": "eslint",
    "migrate": "node scripts/migrate-pg.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "demo:record": "playwright test --config=playwright.demo.config.ts e2e/demo/golden-path.spec.ts",
    "demo:record:full": "playwright test --config=playwright.demo.config.ts e2e/demo/full-tour.spec.ts",
    "demo:screenshots": "playwright test --config=playwright.demo.config.ts e2e/demo/screenshots.spec.ts",
    "demo:record:html": "bash scripts/record-animated-html.sh",
    "demo:pitch": "bash scripts/build-module-pitch.sh",
    "demo:pitches": "bash scripts/build-all-pitches.sh",
    "demo:build": "DEMO_SPEC=golden-path bash scripts/build-demo-video.sh",
    "demo:build:full": "DEMO_SPEC=full-tour bash scripts/build-demo-video.sh"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@types/js-yaml": "^4.0.9",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "js-yaml": "^4.1.1",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^1.8.0",
    "mermaid": "^11.14.0",
    "next": "16.2.3",
    "next-themes": "^0.4.6",
    "pg": "^8.20.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "shadcn": "^4.2.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^9",
    "eslint-config-next": "16.2.3",
    "jsdom": "^29.0.2",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.4"
  }
}
