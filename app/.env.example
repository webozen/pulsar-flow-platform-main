# pulsar-flow-platform (Next.js app under /automation)

# --- HTTP ---
PORT=3002

# Pulsar frontend URL — /automation/login client-redirects back here.
NEXT_PUBLIC_PULSAR_APP_URL=http://localhost:5173

# --- Auth ---
# Must match PULSAR_JWT_SECRET in pulsar-backend. >=32 chars. The public
# sentinel (dev-secret-change-me-please-32bytes-minimum-abcdefgh) is rejected
# in production builds.
PULSAR_JWT_SECRET=changeme-at-least-32-chars-long-dev-only-replace-in-prod

# --- Postgres (flowcore schema) ---
# DB must have the flowcore schema; run `node scripts/migrate-pg.mjs` from
# this directory against a fresh Postgres before first start.
DATABASE_URL=postgresql://kestra:k3stra_dev@localhost:5432/kestra

# --- Kestra workflow engine ---
# Bare-metal default: java -jar kestra.jar server standalone (ports 8081/8088).
KESTRA_API_URL=http://localhost:8088
