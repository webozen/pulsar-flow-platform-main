# Kestra Postgres backend
KESTRA_POSTGRES_PASSWORD=k3stra_dev

# AnythingLLM (Playbooks)
ANYTHINGLLM_API_KEY=playbook-dev-key
GEMINI_API_KEY=your-gemini-api-key-here

# Per-clinic secrets are set via Kestra namespace KV / secrets API.
# See scripts/add-clinic.sh and kestra/namespace-configs/ for details.
#
# Each clinic needs:
#   OPENDENTAL_DB_PASSWORD  — read-only MySQL password for that clinic's Open Dental
#   TWILIO_AUTH_TOKEN        — Twilio auth token
#   SMTP_PASSWORD            — SMTP password for sending emails
